generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== better-auth required models (step 13 で導入済み、保持) =====
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  /// 郵便番号 (任意, 7桁数字, ハイフン無しで保存)。docs/adr/0004-user-maintenance.md §(a) 参照。
  postalCode    String?
  /// "user" or "admin"。マスタ管理画面 (US-012/013) の認可で参照。
  /// docs/adr/0006-master-admin.md §1 参照。
  role          String    @default("user")
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  routes        Route[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// ===== domain models (US-003 to US-007) =====

/// 通勤経路 (1ユーザにつき複数件保持可)。
/// fromStation / toStation は入力項目ではなく、segments の端点
/// (orderIndex 最小/最大) からサーバ保存時に派生算出する派生フィールド。
model Route {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  fromStation String
  toStation   String
  segments    RouteSegment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

/// 経路区間 (1経路につき 1〜10件)。
/// kind は "train" | "subway" | "bus" | "other" のいずれか (app 層 zod で検証)。
/// fromStation / toStation はフリー入力許容のため Station マスタへの FK にしない。
model RouteSegment {
  id          String  @id @default(cuid())
  routeId     String
  route       Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  orderIndex  Int
  kind        String
  lineId      String?
  line        Line?   @relation(fields: [lineId], references: [id], onDelete: SetNull)
  fromStation String
  toStation   String
  fare        Int

  @@index([routeId, orderIndex])
  @@index([lineId])
}

/// 運営会社マスタ (US-049 / ADR 0019)。路線の所属事業者を表す。
/// aliases は表記揺らぎ ("東海旅客鉄道" → "JR東海" 等) を JSON 配列で保持。
model Operator {
  id        String    @id
  name      String    @unique
  aliases   String    @default("[]")
  lines     Line[]
  stations  Station[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// 路線マスタ (経路登録の路線セレクト + 駅マスタ検索のフィルタで参照)。
/// id は手動採番のスラッグ または Wikidata Q-ID (US-011 取り込み分)。
model Line {
  id           String         @id
  kind         String
  name         String         @unique
  /// 互換維持の表示用文字列。Operator マスタ (operatorRef) との関係に置き換え予定。
  operator     String?
  /// US-049 / ADR 0019: 運営会社マスタへの FK。
  operatorId   String?
  operatorRef  Operator?      @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  /// 取り込み元 URI (例: https://www.wikidata.org/wiki/Q1129155)。手動作成は NULL。
  sourceUri    String?
  /// 取り込み実行時刻。手動作成は NULL。
  importedAt   DateTime?
  segments     RouteSegment[]
  stationLinks StationLine[]
}

/// 駅 / 停留所マスタ。種別 (kind) は持たず、接続する Line(s) から派生表示する。
/// US-049 / ADR 0019: 各 Station は単一 operator に属する (operator が異なれば別駅)。
model Station {
  id         String        @id @default(cuid())
  name       String
  kana       String
  /// US-049 / ADR 0019: 駅が属する運営会社。手動作成 (admin) では nullable。
  operatorId String?
  operatorRef Operator?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  /// 取り込み元 URI。手動作成は NULL。docs/adr/0007-tokai-import-spec.md §5。
  sourceUri  String?
  /// US-049: Wikidata 取り込みで複数 Station が同一 Q-ID を共有しうるため
  /// (例: 大曽根 Q872075 が JR + 名鉄で 2 Station に分割), id とは別に保持。
  sourceQid  String?
  /// 取り込み実行時刻。手動作成は NULL。
  importedAt DateTime?
  lineLinks  StationLine[]

  @@index([name])
  @@index([operatorId, name])
  @@index([sourceQid])
}

/// Station ↔ Line の M:N 中間テーブル。
/// docs/adr/0008-station-code-per-line.md: 駅番号は (station, line) ペアごとに採番されるため
/// `code` を中間テーブルに持たせる。手動作成 / 番号未設定の場合は空文字。
model StationLine {
  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  lineId    String
  line      Line    @relation(fields: [lineId], references: [id], onDelete: Cascade)
  /// 駅番号 (Wikidata P296)。同一 (station, line) ペアに複数値があるときは "/" 区切りで連結。
  /// US-033 で導入 (US-030 の Station.code を置換)。
  code      String  @default("")

  @@id([stationId, lineId])
  @@index([lineId])
}
